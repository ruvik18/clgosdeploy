{
  "outputDirectory": "artifacts/counselling/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "^/(?!assets/|logos/|fonts/|favicon\\.png$|robots\\.txt$).*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/data/*.json"
    }
  }
}

